rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. STUDENTS COLLECTION
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 2. STAFF COLLECTION
    match /staff/{staffId} {
      // Allows staff to register themselves and read staff profiles
      allow read, write: if request.auth != null && request.auth.uid == staffId;
      // Allows other authenticated users (like students/admins) to verify staff exists
      allow read: if request.auth != null;
    }

    // 3. ADMIN COLLECTION
    match /admins/{adminId} {
      allow read, write: if request.auth != null && request.auth.uid == adminId;
    }

    // 4. DRAFTS (Only the student can see their own draft)
    match /drafts/{userId} {
    allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 5. APPLICATIONS (Staff can only see these once submitted)
    match /applications/{applicationId} {
    allow read, list: if request.auth != null && (
    request.auth.uid == applicationId || 
    exists(/databases/$(database)/documents/staff/$(request.auth.uid)) ||
    exists(/databases/$(database)/documents/admins/$(request.auth.uid))
  );

      // CREATE: Students can create their own application
      allow create: if request.auth != null && request.auth.uid == applicationId;

      // UPDATE: Student updates their info, Staff/Admin updates status/notes
      allow update: if request.auth != null && (
        request.auth.uid == applicationId || 
        exists(/databases/$(database)/documents/staff/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      ) && request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['step1', 'step2', 'documents', 'draft', 'lastUpdated', 'status', 'adminNote']);
    }

    // 6. DOCUMENT VAULT
    match /documentVault/{docId} {
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow read, update, delete: if request.auth != null && (
        resource.data.ownerId == request.auth.uid || 
        exists(/databases/$(database)/documents/staff/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }
  }
}


