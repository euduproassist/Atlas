rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Users Collection
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // 2. Applications Collection (FIXED)
    match /applications/{applicationId} {
      // FIX: Check the ID of the document itself (userId) instead of a field inside it
      // This ensures a student can only create/edit a document named after their UID
      allow read, write: if request.auth != null && request.auth.uid == applicationId;

      // ENTERPRISE ADDITION: Data Validation
      // This prevents someone from sending 1GB of text data to a single field to crash your Firebase
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['step1', 'step2', 'documents', 'draft', 'lastUpdated', 'status', 'adminNote']);
    }

    // 3. Document Vault (Metadata)
    match /documentVault/{docId} {
      // Ensure the person creating the entry is the owner
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      // Ensure only the owner can see or edit their vault metadata
      allow read, update, delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }
    
    // 4. STORAGE RULES (You must also set these in the Storage Tab of Firebase)
    // Even if Firestore is secure, you need to protect the actual PDF/Images
    // match /applications/{userId}/{allPaths=**} {
    //   allow read, write: if request.auth != null && request.auth.uid == userId;
    // }

    // Allow Staff to manage all applications
    match /applications/{applicationId} {
      allow read, update: if request.auth != null && 
        exists(/databases/$(database)/documents/staff/$(request.auth.uid));
    }

    // Allow the system to check if a user is staff
    match /staff/{staffId} {
      allow read: if request.auth != null;
    }

  }
}
