rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Students Collection
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Staff Collection
    match /staff/{staffId} {
      allow read: if request.auth != null;
      // This line allows them to register themselves
      allow write: if request.auth != null && request.auth.uid == staffId;
    }

    // Admin Collection
    match /admins/{adminId} {
      allow read: if request.auth != null;
      // This line allows them to register themselves
      allow write: if request.auth != null && request.auth.uid == adminId;
    }

    // Applications Management
    match /applications/{applicationId} {
      allow read, list, write: if request.auth != null && (
        request.auth.uid == applicationId || 
        exists(/databases/$(database)/documents/staff/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );

      allow write, update: if request.auth != null && (
        request.auth.uid == applicationId || 
        exists(/databases/$(database)/documents/staff/$(request.auth.uid))
      );

      // Field Validation
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['step1', 'step2', 'documents', 'draft', 'lastUpdated', 'status', 'adminNote']);
    }

    // Document Vault
    match /documentVault/{docId} {
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow read, update, delete: if request.auth != null && (
        resource.data.ownerId == request.auth.uid || 
        exists(/databases/$(database)/documents/staff/$(request.auth.uid))
      );
    }
    
    // Staff Registry
    match /staff/{staffId} {
      allow read: if request.auth != null;
    }
  }
}


