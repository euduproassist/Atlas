rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Rule for the "users" collection (where Full Name, ID, and Phone are stored)
    match /users/{userId} {
      // Students can only read or write their own profile
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Rule for the "applications" collection (where the course portal data lives)
    match /applications/{applicationId} {
      // Allows access only if the 'studentId' field in the document matches the logged-in user
      allow read, write: if request.auth != null && request.resource.data.studentId == request.auth.uid;
      
      // Allows reading existing applications owned by the student
      allow read, update, delete: if request.auth != null && resource.data.studentId == request.auth.uid;
    }

    // Rule for the "documents" vault (metadata for uploaded docs)
    match /documentVault/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == request.resource.data.ownerId;
    }
  }
}

