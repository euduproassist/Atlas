rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is Staff or Admin
    function isStaffOrAdmin() {
      return request.auth != null && (
        exists(/databases/$(database)/documents/staff/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // 1. STUDENTS / USERS COLLECTION
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isStaffOrAdmin());
      // Allow the user to create their profile if the ID matches their Auth UID
      allow create: if request.auth != null && request.auth.uid == userId;
    }

    // 2. STAFF COLLECTION
    match /staff/{staffId} {
      allow read, write: if request.auth != null && request.auth.uid == staffId;
      allow read: if request.auth != null;
    }

    // 3. ADMIN COLLECTION
    match /admins/{adminId} {
      allow read, write: if request.auth != null && request.auth.uid == adminId;
    }

    // 4. DRAFTS
    match /drafts/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 5. APPLICATIONS 
    match /applications/{applicationId} {
      // Duplicate Check
      allow get: if request.auth != null;

      // Browsing/Listing
      allow list: if isStaffOrAdmin();

      // Detailed Read
      allow read: if request.auth != null && (
        request.auth.uid == applicationId || isStaffOrAdmin()
      );

      // This ensures the student can only create an application if they don't already have one for the current cycle
      allow create: if request.auth != null && 
               request.auth.uid == applicationId && 
               !exists(/databases/$(database)/documents/applications/$(applicationId));

       allow update: if request.auth != null && (
    request.auth.uid == applicationId || isStaffOrAdmin()
  ) && (
    isStaffOrAdmin() || 
    request.resource.data.diff(resource.data).affectedKeys()
      .hasAny(['step1', 'step2', 'documents', 'paymentStatus', 'paystackReference', 'paidAt', 'documentStatuses', 'draft', 'lastUpdated', 'status1', 'adminNote', 'studentNumber', 'processedBy', 'actionHistory', 'adminDocs', 'applicationID', 'submittedAt'])
  );
}


    // 6. DOCUMENT VAULT
    match /documentVault/{docId} {
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow read, update, delete: if request.auth != null && (
        resource.data.ownerId == request.auth.uid || isStaffOrAdmin()
      );
    }

    match /mail/{mailId} {
      allow read: if false; 
      allow write: if 
        isStaffOrAdmin() || 
        (request.auth != null && request.resource.data.to == request.auth.token.email);
   }
   
    // 7. SYSTEM CONFIG (Read-only for authenticated users)
    match /system_config/payments {
      allow read: if request.auth != null;
      allow write: if false; 
    }
  
    // New rule for the Application Cycle - Does not affect payments
    match /application_cycles/{cycleId} {
      allow read: if request.auth != null;
      allow write: if isStaffOrAdmin();
    }
    
     match /course_offerings/{courseId} {
     // Students can only see the courses, they cannot add or change them
     allow read: if request.auth != null;
     // Only Staff and Admins can add, update, or delete courses
     allow write: if isStaffOrAdmin();
    }
  }
}






















