rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /applications/{userId}/{fileName} {
      // Allow users to upload and view their own files
      // Allow staff/admins to view all application files
      allow read: if request.auth != null && (
        request.auth.uid == userId || 
        firestore.exists(/databases/(default)/documents/staff/$(request.auth.uid)) ||
        firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid))
      );

    allow write, delete: if request.auth != null && (
    request.auth.uid == userId || 
    firestore.exists(/databases/(default)/documents/staff/$(request.auth.uid))
    );

    }
  }
}







rules_version = '2';

service cloud.firestore {


  match /databases/{database}/documents {

    

    // FIX: Add this so the Dashboard can show the User's Name

    match /users/{userId} {

      allow read: if request.auth != null && request.auth.uid == userId;

      allow write: if false; // Only Staff/Auth should write to the main User profile

    }

    match /drafts/{userId} {

      allow read, write: if request.auth != null && request.auth.uid == userId;

    }

   match /applications/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; 

    }

  }

}
