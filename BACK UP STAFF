<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Staff Portal - Management Dashboard</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
<style>
    :root { 
        --primary: #4a90e2; 
        --bg: #f4f7f9; 
        --border: #e1e4e8; 
        --text: #333; 
    }

    /* Reset & Base */
    * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Segoe UI', Tahoma, sans-serif; }
    body { background-color: var(--bg); color: var(--text); overflow-x: hidden; }

    /* 1. Dashboard Header - Full Width & Clean */
    .dashboard-header {
    background: transparent; /* Colorless header card */
    padding: 20px 25px;
    border-bottom: none;
    box-shadow: none;
    }

    .logo-section {
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 1.25rem;
        font-weight: 700;
        color: #2c3e50;
        white-space: nowrap; /* Prevents logo text from wrapping */
        margin-bottom: 30px;
    }

    .logo-section i { color: var(--primary); }

     /* 2. Toolbar (Filters + Search) */
    .toolbar {
        background: rgba(74, 144, 226, 0.05);
        padding: 15px 25px;
        margin-top: 30px; 
        border-radius: 0;      /* Removed border-radius so it sits flush with the screen edges */
        border-left: none;     /* Optional: remove side borders for a seamless full-width look */
        border-right: none;
        border-top: 1px solid rgba(74, 144, 226, 0.1);
        border-bottom: 1px solid rgba(74, 144, 226, 0.1);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .filters {
        display: flex;
        gap: 8px;
    }

    select, .search-bar input {
        padding: 10px 12px;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: #fff;
        font-size: 0.85rem;
        outline: none;
        transition: border 0.2s;
    }

    select:focus, .search-bar input:focus { border-color: var(--primary); }

    .search-bar {
        position: relative;
        min-width: 240px;
    }

    .search-bar input { width: 100%; padding-right: 35px; }

    .search-bar i {
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: #999;
    }

    /* 3. Main Table Content - Full Screen */
    .main-content {
        width: 100%;
        padding: 0;
    }

    .table-wrapper {
        width: 100%;
        overflow-x: auto; /* Allows horizontal swipe on small phones */
        background: white;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        min-width: 800px; /* Prevents text squashing on mobile */
    }

    th {
        text-align: left;
        padding: 16px 20px;
        background: #f8f9fa;
        font-size: 0.75rem;
        text-transform: uppercase;
        color: #666;
        border-bottom: 2px solid var(--border);
        letter-spacing: 0.5px;
    }

    td {
        padding: 16px 20px;
        border-bottom: 1px solid var(--border);
        font-size: 0.92rem;
        color: #444;
    }

    tr:hover { background-color: #fcfdfe; cursor: pointer; }

    /* 4. Status Pills */
    .status { padding: 4px 10px; border-radius: 4px; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; }
    .status-pending { background: #e3f2fd; color: #1976d2; }
    .status-review { background: #f3e5f5; color: #7b1fa2; }
    .status-missing { background: #fff3e0; color: #ef6c00; }
    .status-prov_accepted { background: #e8f5e9; color: #2e7d32; }
    .status-uncon_accepted { background: #dcedc8; color: #33691e; border: 1px solid #aece90; }
    .status-waiting { background: #eceff1; color: #546e7a; }
    .status-rejected { background: #ffebee; color: #c62828; }
    .status-inactive { 
    background: #f0f0f0; 
    color: #999; 
    border: 1px solid #ddd; 
    padding: 4px 10px; 
    border-radius: 4px; 
    font-size: 0.75rem; 
    font-weight: 600; 
    text-transform: uppercase;
    display: inline-block;
}

    /* 5. Ticket Details Popup */
    .ticket-details {
        margin: 25px;
        background: white;
        border: 1px solid var(--border);
        border-radius: 8px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.08);
        overflow: hidden;
    }

    .details-header { background: #f8f9fa; padding: 15px 20px; font-weight: 700; border-bottom: 1px solid var(--border); }
    .details-body { 
        padding: 25px; 
        display: grid; 
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); 
        gap: 20px; 
    }
    .details-body p { font-size: 0.95rem; line-height: 1.5; }
    .details-body strong { color: #666; width: 130px; display: inline-block; }

    /* Note Section */
    .note-footer { border-top: 1px solid var(--border); padding: 15px 20px; display: flex; align-items: center; gap: 15px; background: #fcfcfc; }
    .note-footer input { flex-grow: 1; padding: 12px; border: 1px solid var(--border); border-radius: 6px; }
    .btn-save { background: var(--primary); color: white; border: none; padding: 12px 25px; border-radius: 6px; font-weight: 600; cursor: pointer; }
    .btn-save:hover { background: #357abd; }

    /* Add this to your <style> section */
    #actionDrop.show {
    display: block !important;
    }
    #actionDrop a:hover {
    background-color: #f1f1f1;
    }

    /* 6. UNIVERSAL RESPONSIVENESS */
    @media (max-width: 1024px) {
        .dashboard-header { flex-direction: column; align-items: flex-start; padding: 15px; }
        .toolbar { width: 100%; justify-content: space-between; margin-top: 10px; }
        .search-bar { flex-grow: 1; }
    }

    @media (max-width: 768px) {
        .hide-mobile { display: none; }
        .toolbar { flex-direction: column; align-items: stretch; gap: 10px; }
        .filters { justify-content: space-between; }
        .filters select { flex: 1; }
        .search-bar { width: 100%; }
        .ticket-details { margin: 10px; }
    }

    /* Add this inside your <style> tag */
    .view-btn {
    padding: 6px 12px;
    cursor: pointer;
    border-radius: 4px;
    font-weight: 700;
    font-size: 0.75rem;
    border: 1px solid transparent;
    transition: background 0.2s;
    }

    .view-btn:hover {
    filter: brightness(0.95);
    }

    /* style: Remove the pointer cursor from the row since it's no longer a big button */
    tr:hover { background-color: #fcfdfe; cursor: default; }

</style>

</head>
<body>

